extends base

block content 
    h4 Change Title of Video
    form(method="POST")
        input(name="title", placeholder="Video Title", value=video.title, required)
        input(name="description", placeholder="Description", type="text", required, minLength=20, value=video.description)
        input(name="hashtags", placeholder="Hashtags, separated by comma.", type="text", required, value=video.hashtags.join())
        input(value="Save", type="submit")
